nextflow_process {

    name "Test Process NCBI_ORTHODB"
    script "modules/local/ncbi_orthodb/main.nf"
    process "NCBI_ORTHODB"
    tag "module"
    tag "ncbi_orthodb"
    tag "ci"

    test("Should run without failures") {

        when {
            process {
                """
                input[0] = tuple([id:"test_sample1", genome_id:"GCA_003719455.1", ena_tax:"default"], "$projectDir/tests/reference_databases/test_sample1_tax_ranks.tsv", "default")
                input[1] = 1
                """
            }
        }

        then {
            assert process.success
            assert snapshot(
                process.out.orthodb_results,
                path(process.out.versions.get(0)).yaml
            ).match()
        }

    }

}
