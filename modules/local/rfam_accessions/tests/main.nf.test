nextflow_process {

    name "Test Process RFAM_ACCESSIONS"
    script "modules/local/rfam_accessions/main.nf"
    process "RFAM_ACCESSIONS"
    tag "module"
    tag "rfam_accessions"

    test("Should run without failures") {

        when {
            process {
                """
                input[0] = tuple([id:"test_sample1", genome_id:"GCA_003719455.1", ena_tax:"default"], "$projectDir/tests/reference_databases/test_sample1_tax_ranks.tsv", "default")
                input[1] = "$projectDir/assets/rfam_db.conf"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                {
                    // Validate Rfam IDs content
                    def rfamDir = process.out.rfam_results.get(0)[1]
                    def rfamIdsFile = path("${rfamDir}/rfam_ids.txt")
                    def lines = rfamIdsFile.readLines()

                    // Format validation
                    assert lines.size() > 0
                    assert lines.every { it ==~ /RF\d{5}/ }

                    // Check for specific Rfam accessions
                    assert lines.contains('RF01554')
                    assert lines.contains('RF01548')
                    assert lines.contains('RF01558')
                },
                {
                    // Snapshot for versions only (not the Rfam IDs content because it can change)
                    assert snapshot(
                        path(process.out.versions.get(0)).yaml
                    ).match()
                }
            )
        }

    }

}
